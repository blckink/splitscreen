<Project Sdk="Microsoft.NET.Sdk">

  <!--
    SplitPlay.TestTarget
    A tiny, self-contained WinForms window used as a deterministic stand-in for a
    game during testing. The launch engine starts it (one per player) when the
    real game cannot provide a second window, or when test mode is on. It also
    shows the live input of its assigned controller, which doubles as a controller
    mapping check. It is bundled next to the app via a project reference.
  -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>SplitPlay.TestTarget</RootNamespace>
    <AssemblyName>SplitPlay.TestTarget</AssemblyName>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\SplitPlay.Core\SplitPlay.Core.csproj" />
    <ProjectReference Include="..\SplitPlay.Input\SplitPlay.Input.csproj" />
  </ItemGroup>

</Project>
