<Window x:Class="SplitPlay.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:SplitPlay.App.Converters"
        xmlns:vm="clr-namespace:SplitPlay.App.ViewModels"
        Title="SplitPlay" Height="760" Width="1180"
        MinHeight="560" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundBrush}"
        TextOptions.TextFormattingMode="Display"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <!-- Custom chrome: we keep native resize/snap but draw our own title bar. -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="48"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </Window.Resources>

    <Border Background="{StaticResource BackgroundBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="48" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- ============================ TOP BAR ============================ -->
            <Border Grid.Row="0" Background="{StaticResource TopBarBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="14,0,8,0">
                        <Border Width="22" Height="22" CornerRadius="4"
                                Background="{StaticResource AccentBrush}">
                            <Grid Margin="4">
                                <Rectangle Fill="#FF10241D" HorizontalAlignment="Left" Width="6" />
                                <Rectangle Fill="#FF10241D" HorizontalAlignment="Right" Width="6" />
                            </Grid>
                        </Border>
                        <TextBlock Text="SplitPlay" Margin="8,0,0,0" VerticalAlignment="Center"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                    </StackPanel>

                    <!-- Search (only on the games grid) -->
                    <Border Grid.Column="1" Width="240" Height="30" CornerRadius="6"
                            Margin="14,0" VerticalAlignment="Center"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Visibility="{Binding IsSearchVisible, Converter={StaticResource BoolToVis}}">
                        <Grid>
                            <TextBlock Text="Search games" Margin="10,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Foreground="{StaticResource TextSecondaryBrush}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding SearchText}" Value="">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center" Margin="8,0"
                                     Foreground="{StaticResource TextPrimaryBrush}"
                                     CaretBrush="{StaticResource TextPrimaryBrush}"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </Border>

                    <!-- Center navigation -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Stretch">
                        <Button Content="Games" Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ShowGamesCommand}"
                                Tag="{Binding IsGamesActive}" />
                        <Button Content="Controls" Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ShowControlsCommand}"
                                Tag="{Binding IsControlsActive}" />
                        <Button Content="Settings" Style="{StaticResource NavButtonStyle}"
                                Command="{Binding ShowSettingsCommand}"
                                Tag="{Binding IsSettingsActive}" />
                    </StackPanel>

                    <!-- Window caption buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Top" HorizontalAlignment="Right">
                        <Button x:Name="MinimizeButton" Style="{StaticResource WindowButtonStyle}"
                                Content="&#xE921;" Click="OnMinimizeClick" ToolTip="Minimize" />
                        <Button x:Name="MaxRestoreButton" Style="{StaticResource WindowButtonStyle}"
                                Content="&#xE922;" Click="OnMaxRestoreClick" ToolTip="Maximize" />
                        <Button x:Name="CloseButton" Style="{StaticResource CloseButtonStyle}"
                                Content="&#xE8BB;" Click="OnCloseClick" ToolTip="Close" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============================ CONTENT ============================ -->
            <!-- The active page view model is rendered via the DataTemplates in App.xaml. -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
        </Grid>
    </Border>
</Window>
