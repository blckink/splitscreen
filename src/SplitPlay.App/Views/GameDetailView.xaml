<UserControl x:Class="SplitPlay.App.Views.GameDetailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SplitPlay.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:GameDetailViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- ============================== HEADER ============================== -->
        <Grid Grid.Row="0" Height="200">
            <Image Source="{Binding Hero}" Stretch="UniformToFill" />
            <!-- Fade the hero into the page background for legible text. -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#9910151A" Offset="0" />
                        <GradientStop Color="#FF1B2027" Offset="1" />
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <Button Content="&#x2039;  Library" Style="{StaticResource SegmentButtonStyle}"
                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="24,18,0,0"
                    Command="{Binding BackCommand}" />

            <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitleStyle}"
                       FontSize="34" VerticalAlignment="Bottom"
                       HorizontalAlignment="Left" Margin="24,0,0,18" />
        </Grid>

        <!-- ============================== CONTENT ============================= -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,22,24,24">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="380" />
                </Grid.ColumnDefinitions>

                <!-- Left column: configuration -->
                <StackPanel Grid.Column="0">

                    <!-- Split orientation -->
                    <TextBlock Text="SCREEN SPLIT" Style="{StaticResource SectionLabelStyle}" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                        <Button Content="Vertical (left / right)" Style="{StaticResource SegmentButtonStyle}"
                                Margin="0,0,10,0" Command="{Binding SetVerticalCommand}"
                                Tag="{Binding IsVertical}" />
                        <Button Content="Horizontal (top / bottom)" Style="{StaticResource SegmentButtonStyle}"
                                Command="{Binding SetHorizontalCommand}"
                                Tag="{Binding IsHorizontal}" />
                    </StackPanel>

                    <!-- Display -->
                    <TextBlock Text="DISPLAY" Style="{StaticResource SectionLabelStyle}" />
                    <ComboBox ItemsSource="{Binding Displays}" SelectedItem="{Binding SelectedDisplay}"
                              DisplayMemberPath="DisplayLabel" Width="320" HorizontalAlignment="Left"
                              Margin="0,0,0,22" Padding="8,5" />

                    <!-- Controllers -->
                    <TextBlock Text="CONTROLLER ASSIGNMENT" Style="{StaticResource SectionLabelStyle}" />
                    <ItemsControl ItemsSource="{Binding Players}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:PlayerSlotViewModel}">
                                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="6"
                                        Padding="14,10" Margin="0,0,0,10" Width="420"
                                        HorizontalAlignment="Left">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center"
                                                   FontSize="15" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding Choices}"
                                                  SelectedItem="{Binding Selected}"
                                                  DisplayMemberPath="Label" Padding="8,5"
                                                  Width="220" HorizontalAlignment="Right" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="Each player needs a different controller. Keyboard/mouse is not supported in split-screen."
                               TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Left"
                               Margin="2,4,0,0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" />
                </StackPanel>

                <!-- Right column: preview + start -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="PREVIEW" Style="{StaticResource SectionLabelStyle}" />

                    <!-- 16:9 preview frame; one of the two layouts is shown at a time. -->
                    <Border Background="#FF11161B" CornerRadius="8" Padding="8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Viewbox Height="200" HorizontalAlignment="Stretch">
                            <Grid Width="356" Height="200">
                                <!-- Vertical: left / right -->
                                <UniformGrid Rows="1" Columns="2"
                                             Visibility="{Binding IsVertical, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{StaticResource AccentBrush}" Margin="0,0,2,0"
                                            CornerRadius="4">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Players[0].DisplayName}" FontWeight="Bold"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Players[0].Selected.Label}"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" FontSize="11" />
                                            <TextBlock Text="{Binding RegionInfoP1}" Opacity="0.75"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SurfaceAltBrush}" Margin="2,0,0,0"
                                            CornerRadius="4">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Players[1].DisplayName}" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Players[1].Selected.Label}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" FontSize="11" />
                                            <TextBlock Text="{Binding RegionInfoP2}" Opacity="0.85"
                                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>

                                <!-- Horizontal: top / bottom -->
                                <UniformGrid Rows="2" Columns="1"
                                             Visibility="{Binding IsHorizontal, Converter={StaticResource BoolToVis}}">
                                    <Border Background="{StaticResource AccentBrush}" Margin="0,0,0,2"
                                            CornerRadius="4">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Players[0].DisplayName}" FontWeight="Bold"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Players[0].Selected.Label}"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" FontSize="11" />
                                            <TextBlock Text="{Binding RegionInfoP1}" Opacity="0.75"
                                                       Foreground="#FF10241D" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <Border Background="{StaticResource SurfaceAltBrush}" Margin="0,2,0,0"
                                            CornerRadius="4">
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding Players[1].DisplayName}" FontWeight="Bold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{Binding Players[1].Selected.Label}"
                                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" FontSize="11" />
                                            <TextBlock Text="{Binding RegionInfoP2}" Opacity="0.85"
                                                       Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </UniformGrid>
                            </Grid>
                        </Viewbox>
                    </Border>

                    <!-- Controller isolation -->
                    <CheckBox Content="Isolate controllers (one pad per window)"
                              IsChecked="{Binding IsolateControllers}" Margin="0,16,0,0"
                              Foreground="{StaticResource TextSecondaryBrush}"
                              ToolTip="Each instance only sees its assigned controller. Keyboard and mouse stay free." />

                    <!-- Test mode -->
                    <CheckBox Content="Test mode (open placeholder windows, don't launch the game)"
                              IsChecked="{Binding UseTestWindows}" Margin="0,8,0,0"
                              Foreground="{StaticResource TextSecondaryBrush}" />

                    <!-- Start -->
                    <Button Content="Start Split-Screen" Style="{StaticResource PrimaryButtonStyle}"
                            Margin="0,12,0,0" HorizontalAlignment="Stretch"
                            Command="{Binding StartCommand}" />

                    <!-- Progress + status -->
                    <ProgressBar Height="6" Margin="0,12,0,0" Minimum="0" Maximum="100"
                                 Value="{Binding Progress, Mode=OneWay}"
                                 Foreground="{StaticResource AccentBrush}"
                                 Background="{StaticResource SurfaceAltBrush}" BorderThickness="0"
                                 Visibility="{Binding IsLaunching, Converter={StaticResource BoolToVis}}" />
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,10,0,0"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
